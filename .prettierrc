{
        "semi": true,
        "singleQuote": true,
        "trailingComma": "es5",
        "printWidth": 100,
        "tabWidth": 8,
        "useTabs": false,
        "bracketSpacing": true,
        "arrowParens": "always",
        "endOfLine": "auto",
        "overrides": [
                {
                        "files": "**/*.{js,jsx,ts,tsx}",
                        "options": {
                                "parser": "babel"
                        }
                }
        ]
}
